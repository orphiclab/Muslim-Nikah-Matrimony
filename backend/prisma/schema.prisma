generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────
enum Role {
  PARENT
  ADMIN
}

enum Gender {
  MALE
  FEMALE
}

enum ProfileStatus {
  DRAFT
  PAYMENT_PENDING
  ACTIVE
  PAUSED
  INACTIVE
  EXPIRED
}

enum SubscriptionStatus {
  ACTIVE
  INACTIVE
  EXPIRED
}

enum PaymentStatus {
  SUCCESS
  PENDING
  FAILED
}

enum PaymentMethod {
  GATEWAY
  BANK_TRANSFER
}

enum PaymentPurpose {
  SUBSCRIPTION
  BOOST
}

enum FieldVisibility {
  PUBLIC
  PRIVATE
}

// ─── Models ──────────────────────────────────────

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  password      String
  role          Role           @default(PARENT)
  phone          String?
  whatsappNumber String?
  phoneVisible   Boolean        @default(true)
  whatsappVisible Boolean       @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  childProfiles ChildProfile[]
  payments      Payment[]
  sentMessages  ChatMessage[]  @relation("SenderMessages")
  passwordResetTokens PasswordResetToken[]
  notifications Notification[]
}

model ChildProfile {
  id                  String         @id @default(uuid())
  memberId            String         @unique  // e.g. MN-001234
  userId              String
  user                User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Basic Info
  name                String
  gender              Gender
  dateOfBirth         DateTime
  height              Int?           // in cm
  weight              Int?           // in kg
  complexion          String?
  appearance          String?
  dressCode           String?
  ethnicity           String?
  civilStatus         String?
  children            String?

  // Location & Education
  country             String?
  city                String?
  state               String?
  residencyStatus     String?
  education           String?
  occupation          String?
  fieldOfStudy        String?
  profession          String?
  annualIncome        String?

  // Family
  familyStatus        String?
  fatherEthnicity     String?
  fatherCountry       String?
  fatherOccupation    String?
  fatherCity          String?
  motherEthnicity     String?
  motherCountry       String?
  motherOccupation    String?
  motherCity          String?
  siblings            Int?
  createdBy           String?

  // Preferences
  minAgePreference    Int?
  maxAgePreference    Int?
  minHeightPreference Int?
  countryPreference   String?

  // Auto-generated (editable)
  aboutUs             String?
  expectations        String?

  // Visibility
  contactVisible      Boolean        @default(true)
  showRealName        Boolean        @default(true)   // if false, nickname is shown publicly
  nickname            String?                         // shown instead of real name when showRealName=false
  boostExpiresAt      DateTime?                       // if set and in future, profile is boosted (shown at top)
  viewCount           Int            @default(0)     // incremented each time profile detail page is viewed
  status              ProfileStatus  @default(DRAFT)
  rejectionReason     String?                         // set by admin when rejecting a payment

  // Field visibility controls
  phoneVisibility     FieldVisibility @default(PRIVATE)
  emailVisibility     FieldVisibility @default(PRIVATE)

  // Phone / contact
  phone               String?
  contactEmail        String?

  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  subscription        Subscription?
  payments            Payment[]
  sentMessages        ChatMessage[]  @relation("ProfileSentMessages")
  receivedMessages    ChatMessage[]  @relation("ProfileReceivedMessages")
}

model Subscription {
  id               String             @id @default(uuid())
  childProfileId   String             @unique
  childProfile     ChildProfile       @relation(fields: [childProfileId], references: [id], onDelete: Cascade)

  status           SubscriptionStatus @default(INACTIVE)
  startDate        DateTime?
  endDate          DateTime?
  planName         String             @default("standard")
  planDurationDays Int                @default(30)

  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
}

model Payment {
  id             String        @id @default(uuid())
  userId         String
  user           User          @relation(fields: [userId], references: [id])
  childProfileId String
  childProfile   ChildProfile  @relation(fields: [childProfileId], references: [id], onDelete: Cascade)

  amount         Float
  currency       String        @default("USD")
  method         PaymentMethod @default(GATEWAY)
  status         PaymentStatus @default(PENDING)
  purpose        PaymentPurpose @default(SUBSCRIPTION)

  // Package reference — lets us know duration at approval time
  packageId             String?
  packageDurationDays   Int?    @default(30)

  // Bank transfer
  bankRef        String?
  bankSlipUrl    String?
  adminNote      String?
  approvedBy     String?
  approvedAt     DateTime?
  rejectionReason String?

  // Gateway
  gatewayRef     String?
  gatewayPayload Json?

  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}


model ChatMessage {
  id               String       @id @default(uuid())
  senderId         String
  sender           User         @relation("SenderMessages", fields: [senderId], references: [id])
  senderProfileId  String
  senderProfile    ChildProfile @relation("ProfileSentMessages", fields: [senderProfileId], references: [id], onDelete: Cascade)
  receiverProfileId String
  receiverProfile  ChildProfile @relation("ProfileReceivedMessages", fields: [receiverProfileId], references: [id], onDelete: Cascade)

  content          String
  imageUrl         String?   // base64 data URL or hosted image URL
  readAt           DateTime?

  createdAt        DateTime     @default(now())
}

model Package {
  id               String   @id @default(uuid())
  name             String
  description      String?
  price            Float
  currency         String   @default("USD")
  durationDays     Int      @default(30)
  features         String[]
  isActive         Boolean  @default(true)
  sortOrder        Int      @default(0)
  type             String   @default("SUBSCRIPTION")

  // Per-package discount
  discountPct      Float?   // e.g. 25.0 = 25% off; null = no package discount
  originalPrice    Float?   // strikethrough price; if null, auto-computed

  // USD pricing (optional)
  usdPrice         Float?   // USD sale price
  usdOriginalPrice Float?   // USD regular/strikethrough price

  isPopular        Boolean  @default(false)

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

/// Single-row settings for site-wide configuration
model SiteSettings {
  id                  String   @id @default("singleton")
  siteDiscountPct     Float    @default(0)
  siteDiscountLabel   String   @default("")
  siteDiscountActive  Boolean  @default(false)
  platformCurrency    String   @default("LKR")

  // Payment contact & bank details
  whatsappContact     String   @default("+94 705 687 697")
  bank1AccName        String   @default("M T M Akram")
  bank1AccNo          String   @default("112054094468")
  bank1BankName       String   @default("Sampath Bank PLC")
  bank1Branch         String   @default("Ratmalana")
  bank2AccName        String   @default("M T M Akram")
  bank2AccNo          String   @default("89870069")
  bank2BankName       String   @default("BOC")
  bank2Branch         String   @default("Anuradhapura")

  updatedAt           DateTime @updatedAt
}

/// SMS OTP for phone verification during registration
model SmsOtp {
  id        String   @id @default(cuid())
  phone     String
  code      String
  verified  Boolean  @default(false)
  attempts  Int      @default(0)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([phone])
}

/// Password reset tokens — one per request, expires in 1 hour
model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

/// Centralised audit log — every important system action lands here
model ActivityLog {
  id          String   @id @default(uuid())

  /// Who did it (null = system / unauthenticated)
  actorId     String?
  actorEmail  String?
  actorRole   String?           // 'ADMIN' | 'PARENT' | 'SYSTEM'

  /// What happened
  action      String            // e.g. 'USER_REGISTERED', 'PAYMENT_APPROVED'
  category    String            // 'AUTH' | 'PROFILE' | 'PAYMENT' | 'ADMIN' | 'SUBSCRIPTION' | 'SYSTEM'

  /// The entity that was affected (profile / user / payment id)
  entityId    String?
  entityLabel String?           // human-readable name, e.g. "MN-000012 – Ayesha"

  /// Optional extra context (JSON blob)
  meta        Json?

  /// Severity: 'INFO' | 'WARNING' | 'ERROR'
  level       String   @default("INFO")

  ipAddress   String?
  userAgent   String?

  createdAt   DateTime @default(now())

  @@index([category])
  @@index([actorId])
  @@index([createdAt])
}

/// In-app notification for users and admins
model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  type      String   // e.g. PAYMENT_APPROVED | NEW_MESSAGE | SUBSCRIPTION_EXPIRING_WEEK
  title     String
  body      String
  isRead    Boolean  @default(false)
  meta      Json?    // optional extra data (paymentId, profileId, reason, etc.)

  createdAt DateTime @default(now())

  @@index([userId, isRead])
  @@index([createdAt])
}

/// SMS Campaign — bulk / scheduled message sent to a group of users
model SmsCampaign {
  id            String            @id @default(uuid())
  name          String
  message       String
  status        String            @default("DRAFT")   // DRAFT | SCHEDULED | SENDING | COMPLETED | FAILED
  recipientType String            @default("ALL")     // ALL | FILTERED | SELECTED
  recipientFilter Json?                               // filter snapshot (gender, country, packageStatus…)
  scheduledAt   DateTime?
  sentAt        DateTime?
  totalRecipients Int             @default(0)
  sentCount     Int               @default(0)
  failedCount   Int               @default(0)
  createdBy     String?                               // admin userId
  templateId    String?
  template      SmsTemplate?      @relation(fields: [templateId], references: [id])
  logs          SmsCampaignLog[]
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([status])
  @@index([createdAt])
}

/// Per-recipient delivery record for each campaign
model SmsCampaignLog {
  id          String       @id @default(uuid())
  campaignId  String
  campaign    SmsCampaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  userId      String
  phone       String
  status      String       @default("PENDING")  // PENDING | SENT | FAILED
  errorMsg    String?
  sentAt      DateTime?
  createdAt   DateTime     @default(now())

  @@index([campaignId])
  @@index([userId])
}

/// Reusable SMS message templates
model SmsTemplate {
  id          String        @id @default(uuid())
  name        String        @unique
  message     String
  category    String        @default("GENERAL")  // GENERAL | WELCOME | REMINDER | PROMOTIONAL
  campaigns   SmsCampaign[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}